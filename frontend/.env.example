# Food Store Frontend — Environment Variables
# Copy this file to .env.local and fill in the values

# Backend API base URL
VITE_API_BASE_URL=http://localhost:8000/api/v1

# MercadoPago — Checkout Pro (Change 19 migration)
# VITE_MP_PUBLIC_KEY is NOT required for Checkout Pro.
# MP hosts the checkout form — no browser tokenization needed.
# Kept commented for reference only.
# VITE_MP_PUBLIC_KEY=TEST-xxxx

# Optional: force sandbox URL even in production builds.
# Set to "true" to always redirect to sandbox_init_point instead of init_point.
# In dev mode (import.meta.env.DEV), sandbox is used automatically.
# VITE_MP_USE_SANDBOX=true
