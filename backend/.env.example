DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/foodstore_dev
TEST_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/foodstore_test
ENVIRONMENT=development
BACKEND_CORS_ORIGINS=http://localhost:5173
API_V1_PREFIX=/api/v1
LOG_LEVEL=INFO
RATE_LIMIT_DEFAULT=100/minute

# --- JWT / Auth (Change 04: backend-base-patterns) ---
# SECRET_KEY: required, no default. Use a long random string (min 32 chars).
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-super-secret-key-change-in-production-do-not-use-this-value
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

ADMIN_EMAIL=admin@foodstore.com
ADMIN_PASSWORD=Admin1234!
