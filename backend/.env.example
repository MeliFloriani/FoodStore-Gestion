DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/foodstore_dev
TEST_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/foodstore_test
ENVIRONMENT=development
# BACKEND_CORS_ORIGINS: origins permitidos por CORSMiddleware (allow_credentials=True).
#   Acepta lista separada por comas o JSON array. NO usar "*" cuando hay credentials.
#   Local dev: incluir ambos hosts (localhost y 127.0.0.1) porque Vite puede servir en cualquiera.
#   Producción: setear SOLO el dominio público real del frontend.
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
API_V1_PREFIX=/api/v1
LOG_LEVEL=INFO
RATE_LIMIT_DEFAULT=100/minute

# --- JWT / Auth (Change 04: backend-base-patterns) ---
# SECRET_KEY: required, no default. Use a long random string (min 32 chars).
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-super-secret-key-change-in-production-do-not-use-this-value
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

ADMIN_EMAIL=admin@foodstore.com
ADMIN_PASSWORD=Admin1234!

# --- Password hashing (Change auth-register-login) ---
BCRYPT_COST=12

# --- MercadoPago Integration (Change 19 — payments-mercadopago-integration) ---
# MP_ACCESS_TOKEN: server-side access token from your MP developer account.
#   Use a TEST-xxxx token for development/sandbox. NEVER expose in frontend.
#   Generate at: https://www.mercadopago.com.ar/settings/account/credentials
MP_ACCESS_TOKEN=TEST-xxxx-your-access-token-here

# MP_PUBLIC_KEY: public key from your MP developer account.
#   Safe to expose in the browser (used by @mercadopago/sdk-react for tokenization).
#   Corresponds to VITE_MP_PUBLIC_KEY in frontend/.env.example
MP_PUBLIC_KEY=TEST-xxxx-your-public-key-here

# MP_WEBHOOK_SECRET: secret used to verify HMAC-SHA256 signatures on incoming webhooks.
#   Set this value in your MP developer dashboard under "Webhook configuration".
#   KEEP PRIVATE — never expose in frontend or version control.
MP_WEBHOOK_SECRET=your-webhook-secret-from-mp-dashboard

# MP_NOTIFICATION_URL: full public URL of the IPN webhook endpoint.
#   Must be reachable by MercadoPago servers (use ngrok for local dev, Change 26 for prod).
#   Format: https://your-domain.com/api/v1/pagos/webhook
MP_NOTIFICATION_URL=https://your-domain.com/api/v1/pagos/webhook

# FRONTEND_BASE_URL: base URL of the frontend app — used to build Checkout Pro back_urls.
#   Must be accessible from the user's browser (not a server-to-server URL).
#   Local dev default: http://localhost:5173
#   Production: set to your real frontend domain (e.g. https://foodstore.com)
FRONTEND_BASE_URL=http://localhost:5173
